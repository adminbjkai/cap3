{
  "$schema": "https://openclaw.dev/schemas/config/v1.json",
  "name": "cap3-audit-system",
  "version": "1.0.0",
  "description": "Kimi K2 Multi-Agent Repository Audit System for Cap3",
  "providers": {
    "moonshot": {
      "baseUrl": "https://api.moonshot.cn/v1",
      "apiKey": "${MOONSHOT_API_KEY}",
      "models": {
        "kimi-k2-thinking": {
          "alias": "orchestrator",
          "contextWindow": 256000,
          "maxTokens": 8192,
          "temperature": 0.3
        },
        "kimi-k2-instruct": {
          "alias": "worker",
          "contextWindow": 128000,
          "maxTokens": 4096,
          "temperature": 0.2
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "provider": "moonshot",
      "model": "moonshot/kimi-k2-instruct",
      "temperature": 0.2,
      "maxTokens": 4096,
      "subagents": {
        "maxConcurrent": 4,
        "maxDepth": 2,
        "runTimeoutSeconds": 600
      }
    },
    "orchestrator": {
      "model": "moonshot/kimi-k2-thinking",
      "temperature": 0.3,
      "maxTokens": 8192,
      "skills": ["audit-orchestrator", "repo-map", "finding-schema"]
    },
    "architecture": {
      "skills": ["finding-schema"]
    },
    "backend": {
      "skills": ["finding-schema"]
    },
    "frontend": {
      "skills": ["finding-schema"]
    },
    "workers": {
      "skills": ["finding-schema"]
    },
    "config": {
      "skills": ["finding-schema"]
    },
    "deps": {
      "skills": ["finding-schema"]
    },
    "docs": {
      "skills": ["finding-schema"]
    },
    "deadcode": {
      "skills": ["finding-schema"]
    },
    "risk": {
      "model": "moonshot/kimi-k2-thinking",
      "skills": ["finding-schema"]
    }
  },
  "orchestration": {
    "mode": "file-based",
    "taskLedger": "TASKS.json",
    "artifactDirectory": "artifacts",
    "evidenceContract": {
      "required": ["finding_id", "category", "severity", "confidence", "summary", "evidence"],
      "schemaVersion": "1.0.0"
    }
  },
  "security": {
    "readOnly": true,
    "allowFileWrites": ["artifacts/", "reports/", "findings/"],
    "shellAllowlist": [
      "rg", "grep", "find", "wc", "jq", "sort", "head", "tail",
      "scc", "cloc",
      "semgrep", "trivy", "gitleaks",
      "git", "cat", "ls"
    ],
    "blockedPaths": [".env", ".env.*", "node_modules/", ".git/"]
  }
}
