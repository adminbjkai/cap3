{
  "$schema": "https://modelcontextprotocol.io/schemas/mcp/v1.json",
  "version": "1.0.0",
  "servers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/m17/2026/gh_repo_tests/cap3"
      ],
      "env": {},
      "description": "Read-only filesystem access to cap3 repository",
      "enabled": true
    },
    "git": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-git",
        "/Users/m17/2026/gh_repo_tests/cap3"
      ],
      "env": {},
      "description": "Git history and blame information",
      "enabled": true
    },
    "code-search": {
      "command": "npx",
      "args": [
        "-y",
        "@ast-grep/mcp-server",
        "--project",
        "/Users/m17/2026/gh_repo_tests/cap3"
      ],
      "env": {},
      "description": "AST-based code search and structural queries",
      "enabled": true
    },
    "shell": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-commands",
        "--whitelist",
        "rg,git,scc,cloc,semgrep,trivy,gitleaks,find,wc,jq"
      ],
      "env": {},
      "description": "Whitelisted shell commands for analysis",
      "enabled": true
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub PR history and issue context (optional)",
      "enabled": false
    }
  }
}
